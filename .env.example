# Vorlage für die .env-Datei.
# Erstelle eine Kopie als .env und trage deine Daten ein.
# Die echte .env wird NICHT versioniert.

# Resend API-Key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verifizierte Absender-Adresse (Domain muss in Resend verifiziert sein).
FROM_EMAIL=kontakt@neufeld.digital

# Empfänger der Anfrage-Mails (die Admin-Benachrichtigung geht hierhin).
TO_EMAIL=kontakt@neufeld.digital
