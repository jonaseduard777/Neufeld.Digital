# Vorlage für die .env-Datei.
# Erstelle eine Kopie als .env und trage deine Daten ein.
# Die echte .env wird NICHT versioniert.

# Gmail-Adresse, die als Absender genutzt wird.
GMAIL_USER=jonaseduard777@gmail.com

# 16-stelliges App-Passwort von Google.
# Hier erstellen: https://myaccount.google.com/apppasswords
# (Voraussetzung: 2-Faktor-Authentifizierung muss im Google-Konto aktiv sein.)
# Die Leerzeichen in der Anzeige darfst du behalten oder entfernen — beides klappt.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Empfänger der Anfrage-Mails (die Admin-Benachrichtigung geht hierhin).
TO_EMAIL=jonaseduard777@gmail.com
